# Binance API Configuration

# Your Binance API Key
API_KEY=your_api_key_here

# Your Binance API Secret
API_SECRET=your_api_secret_here

# Trading Settings
# Define your trading pair
TRADING_PAIR=BTCUSDT

# Set your buy and sell thresholds
BUY_THRESHOLD=30000
SELL_THRESHOLD=40000

# Trading quantity
TRADE_QUANTITY=0.01

# Specify the trading strategy (e.g. "SIMPLE", "ADVANCED")
TRADING_STRATEGY=SIMPLE
